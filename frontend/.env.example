# Public browser config. These values are bundled into the frontend because
# they use the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOAT_RPC_URL=https://rpc.goat.network
NEXT_PUBLIC_GOAT_EXPLORER_URL=https://explorer.goat.network

# Public Stellar network configuration. Testnet is the safe default until all
# production gates pass.
NEXT_PUBLIC_STELLAR_NETWORK=stellar-testnet
NEXT_PUBLIC_STELLAR_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_TESTNET_RPC_FALLBACK_URLS=https://soroban-rpc.testnet.stellar.gateway.fm
NEXT_PUBLIC_STELLAR_TESTNET_DATA_API_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_TESTNET_DATA_API_FALLBACK_URLS=
NEXT_PUBLIC_STELLAR_TESTNET_EXPLORER_URL=https://stellar.expert/explorer/testnet
NEXT_PUBLIC_STELLAR_PUBNET_RPC_URL=https://mainnet.sorobanrpc.com
NEXT_PUBLIC_STELLAR_PUBNET_RPC_FALLBACK_URLS=https://soroban-rpc.mainnet.stellar.gateway.fm
NEXT_PUBLIC_STELLAR_PUBNET_DATA_API_URL=https://horizon.stellar.org
NEXT_PUBLIC_STELLAR_PUBNET_DATA_API_FALLBACK_URLS=https://horizon.stellar.lobstr.co
NEXT_PUBLIC_STELLAR_PUBNET_EXPLORER_URL=https://stellar.expert/explorer/public
NEXT_PUBLIC_STELLAR_RISK_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_STELLAR_TESTNET_RISK_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_STELLAR_PUBNET_RISK_REGISTRY_CONTRACT_ID=
STELLAR_TESTNET_RISK_REGISTRY_ID=
STELLAR_PUBNET_RISK_REGISTRY_ID=

# Server-only storage. Never expose SERVICE_ROLE keys with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only portfolio providers.
# Recommended: multi-chain wallet portfolio with balances, logos, and USD quotes.
GOLDRUSH_API_KEY=
COVALENT_API_KEY=
GOLDRUSH_CHAINS=eth-mainnet,base-mainnet,arbitrum-mainnet,bsc-mainnet,linea-mainnet,matic-mainnet,optimism-mainnet

# Optional server-only fallback: single-chain ERC-20 discovery with Alchemy.
# Supported values for PORTFOLIO_CHAIN: ethereum, base, arbitrum
ALCHEMY_API_KEY=
PORTFOLIO_CHAIN=

# Server-only RPC/provider config.
GOAT_RPC_URL=https://rpc.goat.network
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_RPC_FALLBACK_URLS=https://soroban-rpc.testnet.stellar.gateway.fm
STELLAR_DATA_API_URL=https://horizon-testnet.stellar.org
STELLAR_DATA_API_FALLBACK_URLS=
STELLAR_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_TESTNET_RPC_FALLBACK_URLS=https://soroban-rpc.testnet.stellar.gateway.fm
STELLAR_PUBNET_RPC_URL=https://mainnet.sorobanrpc.com
STELLAR_PUBNET_RPC_FALLBACK_URLS=https://soroban-rpc.mainnet.stellar.gateway.fm
STELLAR_TESTNET_DATA_API_URL=https://horizon-testnet.stellar.org
STELLAR_TESTNET_DATA_API_FALLBACK_URLS=
STELLAR_PUBNET_DATA_API_URL=https://horizon.stellar.org
STELLAR_PUBNET_DATA_API_FALLBACK_URLS=https://horizon.stellar.lobstr.co
# Either provide a manually generated access token:
GOPLUS_API_KEY=
# Or provide app credentials; the server will request and cache access tokens:
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# Server-only x402 premium deep scan config. Production uses Base mainnet and
# the authenticated CDP facilitator. Never commit real CDP credentials.
X402_PAY_TO=0x3ED3E93047b4bCF2e6Ab0744Db08a132d0c97D7d
X402_PRICE_USD=\$0.99
X402_NETWORK=eip155:8453
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
X402_ASSET=USDC
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Optional server-only social providers. Add one later when Social Agent gets
# live engagement metrics.
X_BEARER_TOKEN=
APIFY_TOKEN=
TAVILY_API_KEY=
SOCIAL_DATA_PROVIDER_URL=
